---
interface Props {
  title?: string
  description?: string
  class?: string
}

const {
  title = 'The solo founder operating system',
  description = 'I share what actually works when building AI-native companies alone — systems, tools, mistakes, and wins. One email per week.',
  class: className
} = Astro.props
---

<section class:list={['rounded-xl border border-slate-700 bg-slate-900/60 px-8 py-10 my-12', className]}>
  <div class="max-w-xl">
    <p class="mb-1 text-xs font-semibold uppercase tracking-widest text-accent">Newsletter</p>
    <h2 class="mb-3 text-xl font-bold text-slate-100 sm:text-2xl">{title}</h2>
    <p class="mb-6 text-sm leading-relaxed text-slate-400">{description}</p>
    <form
      action="https://theunnamedroads.ck.page/subscribe"
      method="post"
      class="flex flex-col gap-3 sm:flex-row"
      target="_blank"
      rel="noopener noreferrer"
    >
      <label for="tur-email" class="sr-only">Email address</label>
      <input
        type="email"
        id="tur-email"
        name="email"
        required
        placeholder="your@email.com"
        class="h-10 flex-1 rounded-lg border border-slate-700 bg-slate-800 px-4 text-sm text-slate-100 placeholder:text-slate-500 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
      />
      <button
        type="submit"
        class="h-10 rounded-lg bg-accent px-5 text-sm font-semibold text-white transition-opacity hover:opacity-90 whitespace-nowrap"
      >
        Subscribe
      </button>
    </form>
    <p class="mt-3 text-xs text-slate-600">No spam. Unsubscribe anytime.</p>
  </div>
</section>
